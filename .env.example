# 上游图像 API 配置。
# 不要提交真实 API key；公网部署建议给每个访问 token 单独绑定上游 key。
# OPENAI_BASE_URL 留空时使用官方 OpenAI API；兼容端点示例：https://api.example.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TIMEOUT_MS=1200000

# 服务运行配置。
# Docker Compose 会把容器内 HOST 覆盖为 0.0.0.0，并把 DATA_DIR 覆盖为 /app/data。
PORT=8787
HOST=127.0.0.1
DATA_DIR=./data

# Docker 部署配置。
# APP_DOCKER_NETWORK 需要和你的 Nginx/Caddy/Traefik 反向代理在同一个外部网络。
APP_CONTAINER_NAME=gpt_image_canvas_app
APP_DOCKER_NETWORK=dnmp-infra
NODE_IMAGE=node:23-bullseye-slim
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian
APT_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian-security

# 管理脚本访问地址。
# 运行 scripts/seed-test-access-tokens.mjs 时会用这个地址访问管理员接口。
APP_ORIGIN=http://localhost:8787

# 访问控制。
# 默认开启，适合公网部署；首次启动前必须填写 APP_ADMIN_PASSWORD 和 APP_SESSION_SECRET。
# APP_SESSION_SECRET 至少 32 个字符，可用 `openssl rand -base64 32` 生成。
APP_AUTH_ENABLED=true
APP_ADMIN_PASSWORD=
APP_SESSION_SECRET=
APP_SESSION_DAYS=30

# 可选：启动时自动创建一个朋友访问 token。
# 如果 APP_BOOTSTRAP_ACCESS_TOKEN 不为空，服务启动时会创建这条映射；已存在则跳过。
# 上游配置默认继承 OPENAI_API_KEY / OPENAI_BASE_URL / OPENAI_IMAGE_MODEL，也可以在下面单独覆盖。
APP_BOOTSTRAP_ACCESS_TOKEN=
APP_BOOTSTRAP_ACCESS_LABEL=Test access
APP_BOOTSTRAP_OPENAI_API_KEY=
APP_BOOTSTRAP_OPENAI_BASE_URL=
APP_BOOTSTRAP_OPENAI_IMAGE_MODEL=

# SQLite 存储配置。
# 本地留空时使用 WAL；Docker Compose 默认使用 DELETE + EXCLUSIVE，减少绑定挂载目录上的共享内存问题。
SQLITE_JOURNAL_MODE=
SQLITE_LOCKING_MODE=

# 可选：腾讯云 COS 默认值。
# 应用默认把生成图保存在本地；需要云端备份时，在应用里的云存储弹窗启用 COS。
# 下面这些值只用于预填表单；SecretId 和 SecretKey 需要在 UI 输入，通过测试上传后保存到本地 SQLite。
# UI 保存的 SecretKey 会存入本地数据库，接口只返回掩码，不会回显明文。
COS_DEFAULT_BUCKET=source-1253253332
COS_DEFAULT_REGION=ap-nanjing
COS_DEFAULT_KEY_PREFIX=gpt-image-canvas/assets
